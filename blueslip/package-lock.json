{
  "name": "blueslip",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "blueslip",
      "workspaces": [
        "packages/*",
        "apps/*"
      ]
    },
    "node_modules/@blueslip/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "packages/shared": {
      "name": "@blueslip/shared",
      "version": "0.0.1"
    }
  }
}
